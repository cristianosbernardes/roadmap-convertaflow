# ── Clerk ──────────────────────────────────────────────────────────
# Use as MESMAS chaves do app principal (mesmo projeto Clerk).
# Importante: adicionar "roadmap.convertaflow.com" em Authorized Domains
# no Clerk Dashboard antes do primeiro deploy.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Configurações Clerk (opcional — defaults razoáveis)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Backend ────────────────────────────────────────────────────────
# API ConvertaFlow (backend-python do app principal)
NEXT_PUBLIC_API_URL=https://api.convertaflow.com

# URL do app principal (pra link "Voltar pro app")
NEXT_PUBLIC_APP_URL=https://app.convertaflow.com

# URL da landing page (pra link "Quero conhecer")
NEXT_PUBLIC_LP_URL=https://convertaflow.com

# ── Telemetria / Analytics (opcional) ──────────────────────────────
NEXT_PUBLIC_VERCEL_ANALYTICS=true
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=roadmap.convertaflow.com

# ── Ambiente ───────────────────────────────────────────────────────
# 'development' | 'production'
NEXT_PUBLIC_ENV=development
